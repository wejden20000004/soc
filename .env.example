# Copy to .env and fill in real values. .env is git-ignored.

# --- Host ---------------------------------------------------------------
# LAN IP of the Windows host — handed to enrolling Elastic Agents as the
# Fleet server URL (must be reachable from the endpoint VM).
HOST_LAN_IP=192.168.105.100

# --- SIEM (compose.siem.yml) ---------------------------------------------
ES_PASSWORD=changeme
KIBANA_PASSWORD=changeme-different-from-es
# Any random string of 32+ characters — required by Fleet:
KIBANA_ENCRYPTION_KEY=change-me-to-32-plus-random-characters
# 16GB host defaults; on a 32GB host uncomment the bigger sizing:
# ES_HEAP=-Xms4g -Xmx4g
# ES_MEM_LIMIT=6g

# --- MISP (compose.misp.yml) ----------------------------------------------
MISP_ADMIN_EMAIL=admin@soc.local
MISP_ADMIN_PASSWORD=changeme
MISP_MYSQL_PASSWORD=changeme
MISP_MYSQL_ROOT_PASSWORD=changeme

# --- TheHive (compose.thehive.yml) -----------------------------------------
# Play framework secret — any long random string:
THEHIVE_SECRET=change-me-long-random-string
MINIO_ROOT_USER=thehive
MINIO_ROOT_PASSWORD=changeme-min-8-chars
